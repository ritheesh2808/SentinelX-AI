# SentinelX AI — Backend Environment Variables
# Copy this file to .env and fill in the values

# ====================================================
# Server
# ====================================================
PORT=5000
NODE_ENV=production

# ====================================================
# Database (Neon PostgreSQL)
# Get this from: https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
# ====================================================
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/sentinelx?sslmode=require"

# ====================================================
# Authentication
# Generate with: openssl rand -base64 64
# ====================================================
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_64
JWT_EXPIRES_IN=1h

# ====================================================
# Gemini AI (Google AI Studio)
# Get free key from: https://aistudio.google.com/apikey
# ====================================================
GEMINI_API_KEY=your_gemini_api_key_here
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# ====================================================
# CORS — set to your Vercel frontend URL
# Example: https://sentinelx-ai.vercel.app
# ====================================================
FRONTEND_URL=https://your-app.vercel.app
